generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  creditCards   CreditCard[]
  transactions  Transaction[]
  borrowedExpenses BorrowedExpense[]

  @@map("users")
}

model CreditCard {
  id              String   @id @default(cuid())
  userId          String
  nickname        String
  bankName        String
  cardType        CardType
  lastFourDigits  String   @db.VarChar(4)
  creditLimit     Decimal  @db.Decimal(12, 2)
  billingDate     Int      // day of month
  dueDate         Int      // days after billing date
  cardStatus      CardStatus @default(ACTIVE)

  // Cashback settings
  cashbackType    CashbackType @default(NONE)
  cashbackPercent Decimal? @db.Decimal(5, 2)

  // Cashback cap settings
  cashbackCapType CashbackCapType @default(NO_CAP)
  cashbackCapAmount Decimal? @db.Decimal(10, 2)
  cashbackCapPeriod CashbackCapPeriod?
  quarterStartMonth Int?  // 1, 4, 7, or 10

  // Annual fee settings
  feeType         FeeType  @default(LIFETIME_FREE)
  annualFeeAmount Decimal? @db.Decimal(10, 2)
  joiningFeeAmount Decimal? @db.Decimal(10, 2)
  annualSpendWaiver Decimal? @db.Decimal(12, 2)
  feeRenewalMonth Int?     // month number 1-12

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    Transaction[]
  cashbackRecords CashbackRecord[]
  billingCycles   BillingCycle[]

  @@map("credit_cards")
}

model Transaction {
  id              String   @id @default(cuid())
  userId          String
  cardId          String
  title           String
  amount          Decimal  @db.Decimal(12, 2)
  date            DateTime
  merchantName    String?
  platformType    PlatformType @default(OFFLINE)
  platformSource  String?
  category        Category
  notes           String?
  attachmentUrl   String?
  billingCycleId  String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card            CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  billingCycle    BillingCycle? @relation(fields: [billingCycleId], references: [id])
  cashbackRecord  CashbackRecord?
  borrowedExpense BorrowedExpense?

  @@map("transactions")
}

model BorrowedExpense {
  id              String   @id @default(cuid())
  userId          String
  transactionId   String   @unique
  personName      String
  personType      PersonType
  amountOwed      Decimal  @db.Decimal(12, 2)
  amountReceived  Decimal  @db.Decimal(12, 2) @default(0)
  dueDate         DateTime?
  paymentStatus   PaymentStatus @default(NOT_PAID)
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  repayments      RepaymentRecord[]

  @@map("borrowed_expenses")
}

model RepaymentRecord {
  id              String   @id @default(cuid())
  borrowedId      String
  amount          Decimal  @db.Decimal(12, 2)
  receivedDate    DateTime
  notes           String?

  createdAt       DateTime @default(now())

  borrowedExpense BorrowedExpense @relation(fields: [borrowedId], references: [id], onDelete: Cascade)

  @@map("repayment_records")
}

model CashbackRecord {
  id              String   @id @default(cuid())
  cardId          String
  transactionId   String   @unique
  expectedAmount  Decimal  @db.Decimal(10, 2)
  creditedAmount  Decimal? @db.Decimal(10, 2)
  status          CashbackStatus @default(PENDING)
  creditedDate    DateTime?
  periodStart     DateTime
  periodEnd       DateTime

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  card            CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("cashback_records")
}

model BillingCycle {
  id              String   @id @default(cuid())
  cardId          String
  cycleStart      DateTime
  cycleEnd        DateTime
  dueDate         DateTime
  totalSpend      Decimal  @db.Decimal(12, 2) @default(0)
  paymentStatus   BillingPaymentStatus @default(UNPAID)
  paidAmount      Decimal  @db.Decimal(12, 2) @default(0)
  paidDate        DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  card            CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  transactions    Transaction[]

  @@map("billing_cycles")
}

// Enums
enum CardType {
  VISA
  MASTERCARD
  RUPAY
  AMEX
  DINERS
  OTHER
}

enum CardStatus {
  ACTIVE
  INACTIVE
}

enum CashbackType {
  FLAT
  CATEGORY_BASED
  NONE
}

enum CashbackCapType {
  NO_CAP
  MONTHLY_CAP
  QUARTERLY_CAP
  ANNUAL_CAP
}

enum CashbackCapPeriod {
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum FeeType {
  LIFETIME_FREE
  ANNUAL_FEE
  JOINING_AND_ANNUAL_FEE
}

enum PlatformType {
  ONLINE
  OFFLINE
}

enum Category {
  FOOD
  SHOPPING
  TRAVEL
  UTILITY
  BILLS
  SUBSCRIPTION
  MEDICAL
  FUEL
  OTHERS
}

enum PersonType {
  FRIEND
  FAMILY
  RELATIVE
  COLLEAGUE
  OTHER
}

enum PaymentStatus {
  NOT_PAID
  PARTIALLY_PAID
  FULLY_PAID
}

enum CashbackStatus {
  PENDING
  CREDITED
  MISSED
}

enum BillingPaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}
